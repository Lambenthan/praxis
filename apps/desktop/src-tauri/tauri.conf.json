{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fishes",
  "version": "0.3.0",
  "identifier": "com.fishes.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @fishes/desktop exec vite --port 5173 --strictPort",
    "beforeBuildCommand": "pnpm --filter @fishes/desktop build"
  },
  "app": {
    "windows": [
      {
        "title": "Fishes",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 13,
          "y": 22
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/opencode",
      "binaries/uv",
      "binaries/rg"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    },
    "resources": {
      "../../../runtime/skills/external/ai4s-skills": "skills/",
      "../../../runtime/skills/external/anthropic-skills": "skills-office/",
      "../../../runtime/skills/core": "skills-core/",
      "../../../runtime/agents": "agents/",
      "../../../runtime/plugins": "plugins/",
      "../../../runtime/rules": "rules/",
      "../../../examples": "examples/",
      "python-runtime": "python-runtime/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://fishes-updates-chaw.oss-cn-shanghai.aliyuncs.com/latest.json",
        "https://praxis-updates-chaw.oss-cn-shanghai.aliyuncs.com/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxQjAzQkE2MzQxMThENEUKUldST2pSRTBwanV3SWQrQkcydjBpaGwyVG1ITjhFRW8wR0xSbDNpeEFwSEhPNEpWaDRncnNMR2YK"
    }
  },
  "mainBinaryName": "Fishes"
}
